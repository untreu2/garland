<resources>
    <style name="Widget.Garland.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/garland_surface</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardCornerRadius">0dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.Garland.Panel" parent="">
        <item name="android:background">@drawable/bg_panel_inset</item>
        <item name="android:padding">@dimen/garland_panel_padding</item>
    </style>

    <style name="Widget.Garland.DebugPanel" parent="@style/Widget.Garland.Panel">
        <item name="android:padding">20dp</item>
    </style>

    <style name="Widget.Garland.Section" parent="">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:paddingLeft">@dimen/garland_screen_padding</item>
        <item name="android:paddingTop">24dp</item>
        <item name="android:paddingRight">@dimen/garland_screen_padding</item>
        <item name="android:paddingBottom">24dp</item>
    </style>

    <style name="Widget.Garland.ActionButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="Widget.Garland.ActionButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/garland_leaf</item>
        <item name="android:textColor">@color/garland_ink</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="Widget.Garland.DocumentPickerButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/garland_outline_soft</item>
        <item name="android:textColor">@color/garland_muted</item>
        <item name="backgroundTint">@color/garland_surface_soft</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:minHeight">68dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="Widget.Garland.SubtleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/garland_surface_strong</item>
        <item name="android:textColor">@color/garland_muted</item>
        <item name="backgroundTint">@color/garland_surface_soft</item>
    </style>

    <style name="Widget.Garland.DangerButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/garland_error</item>
        <item name="android:textColor">@color/garland_error</item>
        <item name="backgroundTint">@color/garland_danger_surface</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.Garland.PrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/garland_leaf</item>
        <item name="android:textColor">@color/garland_bg</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.Garland.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/garland_input_surface</item>
        <item name="boxStrokeColor">@color/garland_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/garland_muted_soft</item>
    </style>

    <style name="Widget.Garland.InputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textColorHint">@color/garland_muted_soft</item>
    </style>

    <style name="TextAppearance.Garland.SectionEyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/garland_gold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.Garland.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Garland.DisplayTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Garland.HeroTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Garland.BodyMuted" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/garland_muted</item>
    </style>

    <style name="TextAppearance.Garland.SupportLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/garland_muted_soft</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Garland.BodySupport" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/garland_muted</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.Garland.DiagnosticsBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/garland_muted</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.Garland.BodyStrong" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/garland_ink</item>
    </style>

    <style name="TextAppearance.Garland.HomeTitle" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Garland.DebugTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Garland.DebugCode" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:lineSpacingExtra">5dp</item>
    </style>

    <style name="TextAppearance.Garland.StatusChip" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/garland_ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
</resources>
